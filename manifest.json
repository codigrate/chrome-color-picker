{
  "manifest_version": 3,
  "name": "Color Picker",
  "description": "Pick any color on your screen with the eyedropper and copy it as HEX, RGB or HSL. A fast, simple color picker by Codigrate.",
  "version": "2026.1.0",
  "icons": {
    "16": "images/icon16.png",
    "48": "images/icon48.png",
    "128": "images/icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Color Picker",
    "default_icon": {
      "16": "images/icon16.png",
      "48": "images/icon48.png",
      "128": "images/icon128.png"
    }
  },
  "permissions": [
    "storage"
  ]
}
